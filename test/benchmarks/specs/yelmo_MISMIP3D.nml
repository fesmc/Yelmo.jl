! Yelmo namelist for the MISMIP3D Stnd benchmark, used by
! `MISMIP3DBenchmark` via `run_mirror_benchmark!`. Mirrors
! `/Users/alrobi001/models/yelmo/par-gmd/yelmo_MISMIP3D.nml` with the
! file-loading flags flipped off so initial state comes from the
! Julia `_setup_mismip3d_initial_state!` callback.
!
! Solver block (&ydyn) matches the Yelmo.jl-side test config in
! `test/benchmarks/test_mismip3d_stnd.jl::_mismip3d_yelmo_params`
! to keep both sides in lockstep:
!   solver=ssa, visc_method=1, beta_method=4, beta_q=1/3,
!   beta_u0=1.0, ssa_lat_bc=floating, beta_gl_scale=0,
!   beta_gl_stag=3, eps_0=1e-6, ssa_iter_max=20,
!   ssa_iter_conv=1e-3, ssa_iter_rel=0.7, ssa_vel_max=5000.0.
!
! &yneff method=0 (N_eff = const = 1 Pa).
! &ytill method=1, cf_ref=3.165176e4, is_angle=false (matches Yelmo.jl).
! &ymat rf_method=0, rf_const=3.1536e-18, n_glen=3.0, visc_min=1e3.
!
! Time stepping: dt_method=0 (strict fixed dt), dtt=1.0 — clean
! lockstep with the Yelmo.jl forward-Euler dt=1.0 yr loop. If the
! Fortran side blows up under fixed dt, fall back to dt_method=2
! (PC adaptive) per Phase 1 decision (1) and document.

&ctrl
    domain       = "MISMIP3D"
    experiment   = "Stnd"
    time_init    = 0.0
    time_end     = 500.0
    dtt          = 1.0
    dt2D_out     = 100.0
    dx           = 16.0
/

&yelmo
    domain          = "MISMIP3D"
    grid_name       = "MISMIP3D"
    grid_path       = "none"
    phys_const      = "MISMIP3D"
    experiment      = "MISMIP3D"
    nml_ytopo       = "ytopo"
    nml_ycalv       = "ycalv"
    nml_ydyn        = "ydyn"
    nml_ytill       = "ytill"
    nml_yneff       = "yneff"
    nml_ymat        = "ymat"
    nml_ytherm      = "ytherm"
    nml_masks       = "yelmo_masks"
    nml_init_topo   = "yelmo_init_topo"
    nml_data        = "yelmo_data"
    restart         = "no"
    restart_z_bed   = False
    restart_H_ice   = False
    restart_relax   = 1e3
    log_timestep    = False
    disable_kill    = False
    zeta_scale      = "linear"
    zeta_exp        = 2.0
    nz_aa           = 5
    dt_method       = 0
    dt_min          = 0.1
    cfl_max         = 0.1
    cfl_diff_max    = 0.12
    pc_method       = "AB-SAM"
    pc_controller   = "PI42"
    pc_use_H_pred   = False
    pc_filter_vel   = False
    pc_corr_vel     = False
    pc_n_redo       = 10
    pc_tol          = 5.0
    pc_eps          = 1.0
/

&ytopo
    solver              = "impl-lis"
    surf_gl_method      = 0
    grad_lim            = 0.5
    grad_lim_zb         = 0.5
    dHdt_dyn_lim        = 100.0
    margin2nd           = False
    margin_flt_subgrid  = False
    use_bmb             = False
    topo_fixed          = False
    topo_rel            = 0
    topo_rel_tau        = 10.0
    topo_rel_field      = "H_ref"
    bmb_gl_method       = "pmp"
    gl_sep              = 1
    gz_nx               = 15
    dist_grz            = 200.0
    gz_Hg0              = 0.0
    gz_Hg1              = 0.0
    dmb_method          = 0
    dmb_alpha_max       = 60.0
    dmb_tau             = 100.0
    dmb_sigma_ref       = 300.0
    dmb_m_d             = 3.0
    dmb_m_r             = 1.0
    fmb_method          = 0
    fmb_scale           = 1.0
/

&ycalv
    use_lsf             = False
    dt_lsf              = -1
    calv_flt_method     = "kill-pos"
    calv_grnd_method    = "zero"
    H_min_grnd          = 0.0
    H_min_flt           = 0.0
    sd_min              = 100.0
    sd_max              = 500.0
    calv_grnd_max       = 0.0
    calv_tau            = 1.0
    calv_thin           = 30.0
    k2                  = 3.2e9
    w2                  = 0.0
    kt_ref              = 0.0025
    kt_deep             = 0.1
    tau_ice             = 250.0e3
    Hc_ref_flt          = 200.0
    Hc_ref_grnd         = 200.0
    Hc_ref_thin         = 50.0
    Hc_deep             = 500.0
    zb_deep_0           = -1000.0
    zb_deep_1           = -1500.0
    zb_sigma            = 0.0
/

&ydyn
    solver              = "ssa"
    uz_method           = 3
    visc_method         = 1
    visc_const          = 1e7
    beta_method         = 4
    beta_const          = 1e3
    beta_q              = 0.3333333
    beta_u0             = 1.0
    beta_gl_scale       = 0
    beta_gl_stag        = 3
    beta_gl_f           = 1.0
    taud_gl_method      = 0
    H_grnd_lim          = 500.0
    beta_min            = 0.0
    eps_0               = 1e-6
    scale_T             = 1
    T_frz               = -3.0
    ssa_lis_opt         = "-i bicgsafe -p jacobi -maxiter 1000 -tol 1.0e-6 -initx_zeros false"
    ssa_lat_bc          = "floating"
    ssa_beta_max        = 1e20
    ssa_vel_max         = 5000.0
    ssa_iter_max        = 20
    ssa_iter_rel        = 0.7
    ssa_iter_conv       = 1e-3
    taud_lim            = 1e6
    cb_sia              = 0.0
/

&ytill
    method          = 1
    scale_zb        = 0
    scale_sed       = 0
    is_angle        = False
    n_sd            = 1
    f_sed           = 1.0
    sed_min         = 5.0
    sed_max         = 15.0
    z0              = -300.0
    z1              =  200.0
    cf_min          =  3.165176e4
    cf_ref          =  3.165176e4
/

&yneff
    method          = 0
    nxi             = 0
    const           = 1.0
    p               = 0.0
    H_w_max         = -1.0
    N0              = 1000.0
    delta           = 0.04
    e0              = 0.69
    Cc              = 0.12
    s_const         = 0.5
/

&ymat
    flow_law                = "glen"
    rf_method               = 0
    rf_const                = 3.1536e-18
    rf_use_eismint2         = False
    rf_with_water           = False
    n_glen                  = 3.0
    visc_min                = 1e3
    de_max                  = 0.5
    enh_method              = "shear3D"
    enh_shear               = 1.0
    enh_stream              = 1.0
    enh_shlf                = 1.0
    enh_umin                = 50.0
    enh_umax                = 500.0
    calc_age                = False
    age_iso                 = 0.0
    tracer_method           = "expl"
    tracer_impl_kappa       = 1.5
/

&ytherm
    method          = "fixed"
    qb_method       = 2
    dt_method       = "FE"
    solver_advec    = "impl-upwind"
    gamma           = 1.0
    use_strain_sia  = False
    use_const_cp    = True
    const_cp        = 2009.0
    use_const_kt    = True
    const_kt        = 6.62e7
    enth_cr         = 1e-3
    omega_max       = 0.01
    till_rate       = 0.0
    H_w_max         = 2.0
    rock_method     = "equil"
    nzr_aa          = 5
    zeta_scale_rock = "exp-inv"
    zeta_exp_rock   = 2.0
    H_rock          = 2000.0
    cp_rock         = 1000.0
    kt_rock         = 6.3e7
/

&yelmo_masks
    basins_load     = False
    basins_path     = "none"
    basins_nms      = "basin" "basin_mask"
    regions_load    = False
    regions_path    = "none"
    regions_nms     = "mask" "None"
/

&yelmo_init_topo
    init_topo_load  = False
    init_topo_path  = "none"
    init_topo_names = "H_ice" "z_bed" "z_bed_sd" "z_srf"
    init_topo_state = 0
    z_bed_f_sd      = 0.0
    smooth_H_ice    = 0.0
    smooth_z_bed    = 0.0
/

&yelmo_data
    pd_topo_load      = False
    pd_topo_path      = "none"
    pd_topo_names     = "H_ice" "z_bed" "z_bed_sd" "z_srf"
    pd_tsrf_load      = False
    pd_tsrf_path      = "none"
    pd_tsrf_name      = "T_srf"
    pd_tsrf_monthly   = False
    pd_smb_load       = False
    pd_smb_path       = "none"
    pd_smb_name       = "smb"
    pd_smb_monthly    = False
    pd_vel_load       = False
    pd_vel_path       = "none"
    pd_vel_names      = "ux_srf" "uy_srf"
    pd_age_load       = False
    pd_age_path       = "none"
    pd_age_names      = "age_iso" "depth_iso"
/
