! ----------------------------------------------------------------------
! Namelist for the BUELER-B (Halfar similarity solution) smoke
! benchmark. Drives YelmoMirror via the synthetic-grid path:
! grid axes are passed through `yelmo_init_grid_fromaxes` from Julia,
! all topography / observation file loads are disabled, and the
! benchmark's initial H_ice + boundary fields are set from
! `setup_initial_state!` (Julia-side, after the constructor).
!
! SIA-only dynamics, isothermal, no calving, no mass balance
! (`lambda = 0` in the Halfar formula). Domain spans -750..750 km
! at 50 km resolution → 31×31 cells. Bed is flat (z_bed = 0).
! ----------------------------------------------------------------------

&yelmo
 domain          = 'EISMINT'
 grid_name       = 'EISMINT-EXT'
 grid_path       = ''
 phys_const      = 'EISMINT'
 experiment      = 'BUELER-B'
 nml_ytopo       = 'ytopo'
 nml_ycalv       = 'ycalv'
 nml_ydyn        = 'ydyn'
 nml_ytill       = 'ytill'
 nml_yneff       = 'yneff'
 nml_ymat        = 'ymat'
 nml_ytherm      = 'ytherm'
 nml_masks       = 'yelmo_masks'
 nml_init_topo   = 'yelmo_init_topo'
 nml_data        = 'yelmo_data'
 restart         = 'None'
 restart_z_bed   = .false.
 restart_H_ice   = .false.
 restart_relax   = 0.0
 log_timestep    = .false.
 disable_kill    = .false.
 zeta_scale      = 'exp'
 zeta_exp        = 2.0
 nz_aa           = 10
 dt_method       = 2
 dt_min          = 0.01
 cfl_max         = 0.5
 cfl_diff_max    = 0.12
 pc_method       = 'AB-SAM'
 pc_controller   = 'PI42'
 pc_use_H_pred   = .true.
 pc_filter_vel   = .true.
 pc_corr_vel     = .false.
 pc_n_redo       = 5
 pc_tol          = 5.0
 pc_eps          = 1.0
/

&ytopo
 solver          = 'impl-lis'
 surf_gl_method  = 0
 grad_lim        = 0.05
 grad_lim_zb     = 0.05
 dHdt_dyn_lim    = 100.0
 margin2nd       = .false.
 margin_flt_subgrid = .false.
 use_bmb         = .false.
 topo_fixed      = .false.
 topo_rel        = 0
 topo_rel_tau    = 10.0
 topo_rel_field  = 'H_ref'
 grounded_melt   = .false.
 bmb_gl_method   = 'pmp'
 gl_sep          = 1
 gz_nx           = 15
 dist_grz        = 200.0
 gz_Hg0          = 0.0
 gz_Hg1          = 0.0
 dmb_method      = 0
 dmb_alpha_max   = 60.0
 dmb_tau         = 100.0
 dmb_sigma_ref   = 300.0
 dmb_m_d         = 3.0
 dmb_m_r         = 1.0
 fmb_method      = 0
 fmb_scale       = 1.0
/

&ycalv
 use_lsf         = .false.
 dt_lsf          = -1
 calv_flt_method = 'zero'
 calv_grnd_method = 'zero'
 H_min_grnd      = 0.0
 H_min_flt       = 0.0
 sd_min          = 100.0
 sd_max          = 500.0
 calv_grnd_max   = 0.0
 calv_tau        = 1.0
 calv_thin       = 30.0
 k2              = 3200000000.0
 w2              = 0.0
 kt_ref          = 0.0025
 kt_deep         = 0.1
 tau_ice         = 85000.0
 Hc_ref_flt      = 200.0
 Hc_ref_grnd     = 100.0
 Hc_ref_thin     = 50.0
 Hc_deep         = 500.0
 zb_deep_0       = -1000.0
 zb_deep_1       = -1500.0
 zb_sigma        = 0.0
/

&ydyn
 solver          = 'sia'
 visc_method     = 1
 visc_const      = 10000000.0
 beta_method     = 0
 beta_const      = 1000.0
 beta_q          = 1.0
 beta_u0         = 100.0
 beta_gl_scale   = 0
 beta_gl_stag    = 1
 beta_gl_f       = 1.0
 taud_gl_method  = 0
 H_grnd_lim      = 500.0
 beta_min        = 100.0
 eps_0           = 1e-06
 ssa_lis_opt     = '-i minres -p jacobi -maxiter 100 -tol 1.0e-2 -initx_zeros false'
 ssa_lat_bc      = 'floating'
 ssa_beta_max    = 1e+20
 ssa_vel_max     = 5000.0
 ssa_iter_max    = 5
 ssa_iter_rel    = 0.7
 ssa_iter_conv   = 0.01
 taud_lim        = 1000000.0
 cb_sia          = 0.0
/

&ytill
 method          = 0
 scale           = 'lin'
 is_angle        = .false.
 n_sd            = 1
 f_sed           = 1.0
 sed_min         = 100.0
 sed_max         = 200.0
 z0              = -700.0
 z1              = 700.0
 cf_min          = 0.001
 cf_ref          = 1.0
/

&yneff
 method          = 0
 nxi             = 0
 const           = 10000000.0
 p               = 0.0
 H_w_max         = -1.0
 N0              = 1000.0
 delta           = 0.04
 e0              = 0.69
 Cc              = 0.12
 s_const         = 0.5
/

&ymat
 flow_law        = 'glen'
 rf_method       = 0
 rf_const        = 1e-16
 rf_use_eismint2 = .false.
 rf_with_water   = .false.
 n_glen          = 3.0
 visc_min        = 1000.0
 de_max          = 0.5
 enh_method      = 'shear3D'
 enh_shear       = 1.0
 enh_stream      = 1.0
 enh_shlf        = 1.0
 enh_umin        = 50.0
 enh_umax        = 500.0
 calc_age        = .false.
 age_iso         = 11.7 29.0 57.0 115.0
 tracer_method   = 'expl'
 tracer_impl_kappa = 1.5
/

&ytherm
 method          = 'fixed'
 dt_method       = 'FE'
 solver_advec    = 'impl-upwind'
 gamma           = 1.0
 use_strain_sia  = .false.
 use_const_cp    = .true.
 const_cp        = 2009.0
 use_const_kt    = .true.
 const_kt        = 66200000.0
 enth_cr         = 0.001
 omega_max       = 0.01
 till_rate       = 0.001
 H_w_max         = 2.0
 rock_method     = 'equil'
 nzr_aa          = 5
 zeta_scale_rock = 'exp-inv'
 zeta_exp_rock   = 2.0
 H_rock          = 2000.0
 cp_rock         = 1000.0
 kt_rock         = 63000000.0
/

&yelmo_masks
 basins_load     = .false.
 basins_path     = ''
 basins_nms      = 'basin' 'basin_mask'
 regions_load    = .false.
 regions_path    = ''
 regions_nms     = 'mask' 'None'
/

&yelmo_init_topo
 init_topo_load  = .false.
 init_topo_path  = ''
 init_topo_names = 'H_ice' 'z_bed' 'z_bed_sd' 'z_srf'
 init_topo_state = 0
 z_bed_f_sd      = 0.0
 smooth_H_ice    = 0.0
 smooth_z_bed    = 0.0
/

&yelmo_data
 pd_topo_load    = .false.
 pd_topo_path    = ''
 pd_topo_names   = 'H_ice' 'z_bed' 'z_bed_sd' 'z_srf'
 pd_tsrf_load    = .false.
 pd_tsrf_path    = ''
 pd_tsrf_name    = 'T_srf'
 pd_tsrf_monthly = .false.
 pd_smb_load     = .false.
 pd_smb_path     = ''
 pd_smb_name     = 'smb'
 pd_smb_monthly  = .false.
 pd_vel_load     = .false.
 pd_vel_path     = ''
 pd_vel_names    = 'ux_srf' 'uy_srf'
 pd_age_load     = .false.
 pd_age_path     = ''
 pd_age_names    = 'age_iso' 'depth_iso'
/
